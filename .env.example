# ─── Supabase (cliente — visible en el navegador) ─────────────────────────────
# https://supabase.com → tu proyecto → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Supabase (servidor — NUNCA uses prefijo VITE_) ───────────────────────────
# Misma URL que arriba. service_role en Settings → API → "service_role" (secret)
# Necesaria para: /admin/usuarios, /admin/clientes (crear usuarios, listar clientes)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ────────────────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# ─── Cloudinary ────────────────────────────────────────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# ─── Resend (emails) ───────────────────────────────────────────────────────────
# https://resend.com → API Keys (solo servidor, sin VITE_)
RESEND_API_KEY=
# Remitente: dominio verificado en Resend, o onboarding@resend.dev para pruebas
RESEND_FROM=onboarding@resend.dev
# Destino del formulario de contacto
CONTACT_TO=
# URL pública de la tienda (enlaces en emails)
SITE_URL=https://react-ecommerce-iota-roan.vercel.app
STORE_NAME=Artesana
