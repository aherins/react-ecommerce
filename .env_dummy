# ─── Supabase (cliente — visible en el navegador) ─────────────────────────────
# https://supabase.com → tu proyecto → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Supabase (servidor — NUNCA uses prefijo VITE_) ───────────────────────────
# Misma URL que arriba. service_role en Settings → API → "service_role" (secret)
# Necesaria para: /admin/usuarios, /admin/clientes (crear usuarios, listar clientes)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google OAuth (requiere Supabase) ──────────────────────────────────────────
# 1. Ve a https://console.cloud.google.com → APIs & Services → Credentials
# 2. Crea un OAuth 2.0 Client ID (tipo "Web application")
# 3. En "Authorized redirect URIs" añade:
#    https://<tu-proyecto>.supabase.co/auth/v1/callback
# 4. Copia Client ID y Secret en Supabase → Auth → Providers → Google
# (No necesitas añadir nada aquí — Supabase gestiona el flujo)

VITE_GOOGLE_CLIENT_ID=
VITE_API_KEY=

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Consigue estas en: https://dashboard.stripe.com/apikeys
# Mientras no tengas credenciales, deja estas variables vacías → modo simulación activo
VITE_STRIPE_PUBLISHABLE_KEY=
# Esta clave es SECRETA — solo para Vercel Edge Functions / backend
STRIPE_SECRET_KEY=

# ─── Cloudinary ────────────────────────────────────────────────────────────────
# Consigue en: https://cloudinary.com → Dashboard
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
# El upload preset debe ser "Unsigned" en Cloudinary → Settings → Upload presets

# ─── Resend (emails) ───────────────────────────────────────────────────────────
# Consigue en: https://resend.com → API Keys
# Solo se usa desde Vercel Edge Functions (no exponer al cliente)
RESEND_API_KEY=
RESEND_FROM=info2@misitio.com
CONTACT_TO=
SITE_URL=
STORE_NAME=Artesana


